# Stripe secret key (use a test key for development, e.g. sk_test_...)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Optional: explicit base URL used for Stripe redirect URLs.
# If not set, the server derives it from the incoming request.
# Example for Railway: https://your-app-name.up.railway.app
BASE_URL=

# Port the server listens on (Railway sets this automatically)
PORT=3000
